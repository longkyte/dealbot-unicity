# Unicity Sphere SDK Config
UNICITY_NETWORK=testnet
UNICITY_ESCROW_ADDRESS=DIRECT://03f2a8c3d9... # Or nametag of escrow service
UNICITY_DATA_DIR=./wallet-data
UNICITY_MNEMONIC="your twelve word seed phrase here for real testnet v2 connection"

# DealBot Mode
# Set to true to run with the LocalSimulationAdapter for testing and off-chain demos.
# Set to false to attempt real Sphere SDK calls on Unicity Testnet v2.
DEALBOT_SIMULATION=true
